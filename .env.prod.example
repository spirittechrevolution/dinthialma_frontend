# ===================================================================
# Dinthialma Frontend – Variables d'environnement BUILD
# ===================================================================
# Ces variables sont injectées AU BUILD par Docker (ARG → ENV).
# Elles sont compilées dans le bundle Vite : import.meta.env.VITE_*
#
# En production elles sont passées via docker-compose.prod.yml (args:).
# Ce fichier sert uniquement de référence documentaire.
# ===================================================================

# URL de l'API backend Spring Boot
# En production : https://api.dinthialma.com
VITE_API_URL=http://localhost:8081
